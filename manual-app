function mobileNav(tab){
  document.querySelectorAll('.mobile-nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('mnav-'+tab).classList.add('active');
  closeMobileSidebar();
  if(tab==='list')showAllManuals();
  else if(tab==='new')openNewForm();
  else if(tab==='history')document.getElementById('history-panel').classList.add('open');
  else if(tab==='menu'){
    document.getElementById('mobile-sidebar').classList.toggle('open');
    document.getElementById('mobile-category-list').innerHTML=document.getElementById('category-list').innerHTML;
  }
}
function closeMobileSidebar(){document.getElementById('mobile-sidebar').classList.remove('open');}

function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.addEventListener('click',e=>{if(e.target.classList.contains('modal-overlay'))e.target.classList.remove('open');});

function showToast(msg,type='',duration=3000){
  const container=document.getElementById('toast-container');
  const toast=document.createElement('div');
  toast.className='toast'+(type?' '+type:'');toast.textContent=msg;
  container.appendChild(toast);
  setTimeout(()=>{toast.style.opacity='0';toast.style.transition='opacity .3s';setTimeout(()=>toast.remove(),300);},duration);
}
function escH(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');}
function escA(s){return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#039;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
</script>
