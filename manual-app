<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<title>業務マニュアル管理システム</title>
<style>
:root {
  --primary: #2563eb; --primary-dark: #1d4ed8; --success: #059669;
  --danger: #dc2626; --warning: #d97706;
  --bg: #f8fafc; --surface: #ffffff; --surface2: #f1f5f9;
  --border: #e2e8f0; --text: #1e293b; --text2: #64748b; --text3: #94a3b8;
  --shadow: 0 1px 3px rgba(0,0,0,.1); --shadow-md: 0 4px 6px -1px rgba(0,0,0,.1); --shadow-lg: 0 10px 15px -3px rgba(0,0,0,.1);
  --radius: 8px; --radius-lg: 12px;
  --font: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Yu Gothic', Meiryo, sans-serif;
}
[data-theme="dark"] {
  --bg:#0f172a; --surface:#1e293b; --surface2:#334155;
  --border:#475569; --text:#f1f5f9; --text2:#94a3b8; --text3:#64748b;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:15px;line-height:1.6;min-height:100vh;transition:background .3s,color .3s;}
::-webkit-scrollbar{width:6px;height:6px;}
::-webkit-scrollbar-track{background:var(--surface2);}
::-webkit-scrollbar-thumb{background:var(--text3);border-radius:3px;}

#app-header{
  position:sticky;top:0;z-index:100;background:var(--primary);color:#fff;
  padding:0 16px;height:56px;display:flex;align-items:center;justify-content:space-between;
  box-shadow:var(--shadow-md);
}
#app-header h1{font-size:17px;font-weight:700;display:flex;align-items:center;gap:8px;}
.header-actions{display:flex;gap:6px;align-items:center;}
.icon-btn{
  background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:8px;
  padding:7px 10px;cursor:pointer;font-size:13px;display:flex;align-items:center;gap:4px;
  transition:all .2s;white-space:nowrap;
}
.icon-btn:hover{background:rgba(255,255,255,.35);}
.icon-btn.danger{background:rgba(220,38,38,.6);}

#main-wrapper{display:flex;min-height:calc(100vh - 56px);}

#sidebar{
  width:260px;min-width:260px;background:var(--surface);
  border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;
}
#sidebar-header{padding:16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
#sidebar-header h2{font-size:12px;color:var(--text2);font-weight:700;text-transform:uppercase;letter-spacing:.5px;}
#new-manual-btn{
  background:var(--primary);color:#fff;border:none;border-radius:var(--radius);
  padding:7px 12px;cursor:pointer;font-size:13px;font-weight:600;display:flex;align-items:center;gap:5px;
}
#search-box{padding:10px 12px;border-bottom:1px solid var(--border);}
#search-input{
  width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius);
  background:var(--bg);color:var(--text);font-size:13px;outline:none;
}
#search-input:focus{border-color:var(--primary);}
#category-list{flex:1;overflow-y:auto;padding:6px 0;}
.cat-main{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 16px;cursor:pointer;font-weight:600;font-size:14px;color:var(--text);
  transition:all .2s;user-select:none;
}
.cat-main:hover{background:var(--surface2);}
.cat-main .arrow{font-size:11px;color:var(--text3);transition:transform .2s;}
.cat-main.open .arrow{transform:rotate(90deg);}
.cat-sub-list{display:none;}
.cat-main.open + .cat-sub-list{display:block;}
.cat-sub-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:7px 12px 7px 28px;cursor:pointer;font-size:13px;color:var(--text2);transition:all .2s;
}
.cat-sub-item:hover{background:var(--surface2);color:var(--text);}
.cat-sub-item.active{background:#dbeafe;color:var(--primary);font-weight:600;}
[data-theme="dark"] .cat-sub-item.active{background:#1e3a5f;}
.item-count{background:var(--border);color:var(--text2);border-radius:10px;font-size:11px;padding:1px 7px;text-align:center;}

#content-area{flex:1;overflow-y:auto;padding:24px;background:var(--bg);}

#welcome-screen{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:400px;text-align:center;color:var(--text2);gap:16px;
}
#welcome-screen .icon{font-size:64px;}
#welcome-screen h2{font-size:22px;color:var(--text);font-weight:700;}
#welcome-screen p{font-size:14px;line-height:1.8;}
.welcome-actions{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:8px;}
.welcome-actions button{
  background:var(--primary);color:#fff;border:none;border-radius:var(--radius);
  padding:12px 24px;cursor:pointer;font-size:14px;font-weight:600;
  display:flex;align-items:center;gap:8px;transition:all .2s;
}
.welcome-actions button:hover{background:var(--primary-dark);}
.welcome-actions button.secondary{background:var(--surface);color:var(--text);border:1px solid var(--border);}
.welcome-actions button.secondary:hover{background:var(--surface2);}

#manual-list-view{display:none;}
#manual-list-view h2{font-size:20px;font-weight:700;margin-bottom:20px;padding-bottom:12px;border-bottom:2px solid var(--border);display:flex;align-items:center;gap:10px;}
.badge{background:var(--primary);color:#fff;font-size:12px;padding:2px 9px;border-radius:12px;font-weight:600;}
.manual-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;}
.manual-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);
  padding:20px;cursor:pointer;transition:all .2s;box-shadow:var(--shadow);
}
.manual-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px);}
.manual-card .card-badge{
  display:inline-flex;align-items:center;gap:4px;background:#dbeafe;color:var(--primary);
  font-size:11px;font-weight:600;padding:3px 9px;border-radius:12px;margin-bottom:10px;
}
[data-theme="dark"] .manual-card .card-badge{background:#1e3a5f;}
.manual-card h3{font-size:16px;font-weight:700;margin-bottom:6px;}
.manual-card .card-desc{font-size:13px;color:var(--text2);line-height:1.5;}
.manual-card .card-meta{
  display:flex;align-items:center;justify-content:space-between;
  margin-top:14px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;color:var(--text3);
}
.card-actions{display:flex;gap:6px;}
.card-btn{
  background:var(--surface2);border:none;border-radius:var(--radius);
  padding:5px 10px;cursor:pointer;font-size:12px;color:var(--text2);transition:all .2s;
}
.card-btn:hover{background:var(--border);color:var(--text);}
.card-btn.danger:hover{background:#fee2e2;color:var(--danger);}

#edit-view{display:none;}
.form-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid var(--border);flex-wrap:wrap;gap:12px;
}
.form-header h2{font-size:20px;font-weight:700;display:flex;align-items:center;gap:10px;}
.form-actions{display:flex;gap:8px;flex-wrap:wrap;}
.btn{
  border:none;border-radius:var(--radius);padding:9px 18px;cursor:pointer;
  font-size:14px;font-weight:600;display:flex;align-items:center;gap:6px;transition:all .2s;white-space:nowrap;
}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{background:var(--primary-dark);}
.btn-secondary{background:var(--surface2);color:var(--text);border:1px solid var(--border);}
.btn-secondary:hover{background:var(--border);}
.btn-danger{background:var(--danger);color:#fff;}
.btn-danger:hover{background:#b91c1c;}
.btn-success{background:var(--success);color:#fff;}
.btn-success:hover{background:#047857;}
.btn-warning{background:var(--warning);color:#fff;}
.btn-warning:hover{background:#b45309;}
.form-section{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius-lg);padding:20px;margin-bottom:20px;box-shadow:var(--shadow);
}
.form-section h3{
  font-size:15px;font-weight:700;margin-bottom:16px;color:var(--text);
  display:flex;align-items:center;gap:8px;padding-bottom:10px;border-bottom:1px solid var(--border);
}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:14px;}
.form-group{margin-bottom:14px;}
label{display:block;font-size:13px;font-weight:600;color:var(--text2);margin-bottom:6px;}
label .required{color:var(--danger);margin-left:2px;}
input[type="text"],select,textarea{
  width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:var(--radius);
  background:var(--bg);color:var(--text);font-size:14px;font-family:var(--font);
  outline:none;transition:all .2s;-webkit-appearance:none;
}
input[type="text"]:focus,select:focus,textarea:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(37,99,235,.15);}
textarea{resize:vertical;min-height:80px;}

.step-list{display:flex;flex-direction:column;gap:12px;}
.step-card{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:16px;}
.step-card-header{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.step-number{
  width:28px;height:28px;background:var(--primary);color:#fff;border-radius:50%;
  display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;
}
.step-remove-btn{background:none;border:none;color:var(--text3);cursor:pointer;font-size:18px;padding:2px;transition:all .2s;line-height:1;margin-left:auto;}
.step-remove-btn:hover{color:var(--danger);}
.step-fields{display:flex;flex-direction:column;gap:10px;}
.step-field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}

.media-upload-zone{
  border:2px dashed var(--border);border-radius:var(--radius);padding:24px;
  text-align:center;cursor:pointer;transition:all .2s;color:var(--text3);font-size:13px;
}
.media-upload-zone:hover,.media-upload-zone.drag-over{border-color:var(--primary);background:#eff6ff;color:var(--primary);}
[data-theme="dark"] .media-upload-zone:hover{background:#1e3a5f;}
.media-upload-zone .upload-icon{font-size:32px;margin-bottom:8px;}
.media-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;margin-top:12px;}
.media-item{position:relative;border-radius:var(--radius);overflow:hidden;background:var(--surface2);aspect-ratio:4/3;}
.media-item img,.media-item video{width:100%;height:100%;object-fit:cover;}
.media-del{
  position:absolute;top:4px;right:4px;background:rgba(220,38,38,.85);color:#fff;
  border:none;border-radius:50%;width:24px;height:24px;cursor:pointer;
  font-size:14px;display:flex;align-items:center;justify-content:center;line-height:1;
}
.media-type-badge{position:absolute;bottom:4px;left:4px;background:rgba(0,0,0,.6);color:#fff;font-size:10px;padding:2px 6px;border-radius:4px;}

#detail-view{display:none;}
.detail-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;gap:12px;flex-wrap:wrap;}
.detail-header-info .breadcrumb{font-size:13px;color:var(--text3);margin-bottom:8px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.detail-header-info h2{font-size:24px;font-weight:700;}
.detail-header-actions{display:flex;gap:8px;flex-wrap:wrap;}
.detail-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;margin-bottom:20px;box-shadow:var(--shadow);}
.detail-section h3{font-size:15px;font-weight:700;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;}
.detail-desc{font-size:14px;line-height:1.8;white-space:pre-wrap;word-break:break-word;}
.step-detail-card{border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:12px;background:var(--bg);}
.step-detail-num{display:inline-flex;align-items:center;gap:8px;font-weight:700;color:var(--primary);font-size:15px;margin-bottom:10px;}
.step-detail-num span{width:26px;height:26px;background:var(--primary);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;}
.step-block{margin-bottom:10px;}
.step-block-label{font-size:12px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
.step-block-text{font-size:14px;line-height:1.7;white-space:pre-wrap;word-break:break-word;}
.point-box{background:#fffbeb;border-left:3px solid var(--warning);border-radius:0 var(--radius) var(--radius) 0;padding:10px 14px;font-size:14px;line-height:1.7;color:#92400e;}
.caution-box{background:#fff1f2;border-left:3px solid var(--danger);border-radius:0 var(--radius) var(--radius) 0;padding:10px 14px;font-size:14px;line-height:1.7;color:#9b1c1c;}
[data-theme="dark"] .point-box{background:#2d1b00;color:#fcd34d;}
[data-theme="dark"] .caution-box{background:#2d0000;color:#fca5a5;}

#history-panel{
  display:none;position:fixed;top:56px;right:0;bottom:0;width:320px;
  background:var(--surface);border-left:1px solid var(--border);
  box-shadow:var(--shadow-lg);z-index:200;overflow-y:auto;flex-direction:column;
}
#history-panel.open{display:flex;}
#history-panel-header{
  padding:16px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;background:var(--surface);
}
#close-history-btn{background:none;border:none;cursor:pointer;font-size:20px;color:var(--text2);}
.history-list{padding:10px;flex:1;}
.history-item{border:1px solid var(--border);border-radius:var(--radius);padding:12px;margin-bottom:8px;cursor:pointer;transition:all .2s;background:var(--bg);}
.history-item:hover{background:var(--surface2);border-color:var(--primary);}
.history-item .h-action{font-size:12px;font-weight:700;color:var(--primary);margin-bottom:4px;}
.history-item .h-title{font-size:14px;font-weight:600;margin-bottom:4px;}
.history-item .h-time{font-size:11px;color:var(--text3);}
.history-empty{text-align:center;color:var(--text3);padding:40px 20px;font-size:14px;}

.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border-radius:var(--radius-lg);padding:24px;max-width:440px;width:100%;box-shadow:var(--shadow-lg);animation:fadeIn .2s ease;}
@keyframes fadeIn{from{opacity:0;transform:scale(.95);}to{opacity:1;transform:scale(1);}}
.modal h3{font-size:18px;font-weight:700;margin-bottom:10px;}
.modal p{font-size:14px;color:var(--text2);margin-bottom:20px;line-height:1.7;}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;}

#toast-container{position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;}
.toast{
  background:var(--text);color:var(--surface);padding:12px 18px;border-radius:var(--radius);
  font-size:14px;box-shadow:var(--shadow-lg);animation:slideUp .3s ease;pointer-events:auto;
  display:flex;align-items:center;gap:8px;max-width:300px;word-break:break-word;
}
.toast.success{background:var(--success);}
.toast.danger{background:var(--danger);}
.toast.warning{background:var(--warning);}
@keyframes slideUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}

#mobile-nav{
  display:none;position:fixed;bottom:0;left:0;right:0;
  background:var(--surface);border-top:1px solid var(--border);z-index:150;
  padding:6px 0 env(safe-area-inset-bottom,0);
}
.mobile-nav-inner{display:flex;justify-content:space-around;}
.mobile-nav-btn{
  background:none;border:none;display:flex;flex-direction:column;align-items:center;gap:3px;
  padding:6px 10px;cursor:pointer;font-size:11px;color:var(--text3);transition:all .2s;flex:1;
}
.mobile-nav-btn .nav-icon{font-size:22px;}
.mobile-nav-btn.active{color:var(--primary);}
#mobile-sidebar{display:none;position:fixed;inset:56px 0 60px 0;background:var(--surface);z-index:120;overflow-y:auto;}
#mobile-sidebar.open{display:block;}

@media(max-width:768px){
  #sidebar{display:none;}
  #mobile-nav{display:block;}
  #content-area{padding:16px 12px 80px;}
  .form-row{grid-template-columns:1fr;}
  .step-field-row{grid-template-columns:1fr;}
  .manual-cards{grid-template-columns:1fr;}
  .media-grid{grid-template-columns:repeat(auto-fill,minmax(100px,1fr));}
  .form-header{flex-direction:column;align-items:flex-start;}
  .detail-header{flex-direction:column;}
  #history-panel{width:100%;}
  .icon-btn span{display:none;}
}

@media print{
  *{-webkit-print-color-adjust:exact !important;print-color-adjust:exact !important;}
  @page{size:A4;margin:15mm;}
  #app-header,#sidebar,#mobile-nav,#mobile-sidebar,#history-panel,#toast-container,
  .form-actions,.detail-header-actions,.print-hide,.card-btn,.media-del{display:none !important;}
  body{background:#fff !important;color:#000 !important;font-size:11pt;}
  #content-area{padding:0;}
  #detail-view{display:block !important;}
  #welcome-screen,#manual-list-view,#edit-view{display:none !important;}
  .detail-section{border:1px solid #ccc;page-break-inside:avoid;margin-bottom:10mm;box-shadow:none !important;}
  .point-box{background:#fffbeb !important;border-left:3px solid #d97706 !important;}
  .caution-box{background:#fff1f2 !important;border-left:3px solid #dc2626 !important;}
  .print-title{font-size:18pt;font-weight:bold;text-align:center;margin-bottom:6mm;padding-bottom:4mm;border-bottom:2pt solid #000;}
  .print-meta{font-size:9pt;color:#666;text-align:right;margin-bottom:8mm;}
}
</style>
</head>
<body>

<header id="app-header">
  <h1>📋 <span>業務マニュアル</span></h1>
  <div class="header-actions">
    <button class="icon-btn" onclick="toggleHistory()">📜 <span>履歴</span></button>
    <button class="icon-btn" onclick="exportData()">⬆️ <span>保存</span></button>
    <button class="icon-btn" onclick="triggerImport()">⬇️ <span>読込</span></button>
    <button class="icon-btn" onclick="toggleDark()">🌙</button>
    <button class="icon-btn danger" onclick="showResetModal()">🗑️</button>
    <input type="file" id="import-file-input" accept=".json" style="display:none" onchange="importData(event)">
  </div>
</header>

<div id="main-wrapper">
  <nav id="sidebar">
    <div id="sidebar-header">
      <h2>📁 マニュアル</h2>
      <button id="new-manual-btn" onclick="openNewForm()">＋ 新規</button>
    </div>
    <div id="search-box">
      <input type="text" id="search-input" placeholder="🔍 検索..." oninput="filterList(this.value)">
    </div>
    <div id="category-list"></div>
  </nav>

  <main id="content-area">
    <div id="welcome-screen">
      <div class="icon">📋</div>
      <h2>業務マニュアル管理システム</h2>
      <p>会社や店舗の業務マニュアルを簡単に作成・管理できます。<br>iPhoneでもパソコンでも快適に使えます。</p>
      <div class="welcome-actions">
        <button onclick="openNewForm()">＋ 新規マニュアルを作成</button>
        <button class="secondary" onclick="showAllManuals()">📂 一覧を見る</button>
        <button class="secondary" onclick="loadSampleData()">📝 サンプルを読み込む</button>
      </div>
    </div>

    <div id="manual-list-view">
      <h2 id="list-title">📂 全マニュアル一覧 <span class="badge" id="total-count">0</span></h2>
      <div class="manual-cards" id="manual-cards-container"></div>
    </div>

    <div id="edit-view">
      <div class="form-header">
        <h2 id="form-title">✏️ 新規マニュアル作成</h2>
        <div class="form-actions">
          <button class="btn btn-secondary" onclick="cancelEdit()">✖ キャンセル</button>
          <button class="btn btn-warning" onclick="undoHistory()">↩ 元に戻す</button>
          <button class="btn btn-primary" onclick="saveManual()">💾 保存</button>
        </div>
      </div>
      <div class="form-section">
        <h3>📌 基本情報</h3>
        <div class="form-row">
          <div class="form-group">
            <label>大カテゴリー <span class="required">*</span></label>
            <input type="text" id="f-main-cat" placeholder="例：接客・販売、製造、事務" list="main-cat-list">
            <datalist id="main-cat-list"></datalist>
          </div>
          <div class="form-group">
            <label>中カテゴリー <span class="required">*</span></label>
            <input type="text" id="f-sub-cat" placeholder="例：レジ操作、商品陳列" list="sub-cat-list">
            <datalist id="sub-cat-list"></datalist>
          </div>
        </div>
        <div class="form-group">
          <label>マニュアルタイトル <span class="required">*</span></label>
          <input type="text" id="f-title" placeholder="例：レジ打ちの基本操作">
        </div>
        <div class="form-group">
          <label>簡易説明（概要）</label>
          <textarea id="f-desc" rows="3" placeholder="このマニュアルの目的や対象者を簡潔に説明してください"></textarea>
        </div>
        <div class="form-group">
          <label>注意事項（全体）</label>
          <textarea id="f-caution" rows="3" placeholder="マニュアル全体に関わる注意事項を記入してください"></textarea>
        </div>
      </div>
      <div class="form-section">
        <h3>🔢 作業工程</h3>
        <div class="step-list" id="step-list"></div>
        <button class="btn btn-secondary" style="margin-top:12px" onclick="addStep()">＋ 工程を追加</button>
      </div>
      <div class="form-section">
        <h3>🖼️ 写真・動画</h3>
        <div class="media-upload-zone" id="upload-zone"
             onclick="document.getElementById('media-input').click()"
             ondragover="onDragOver(event)" ondragleave="onDragLeave()" ondrop="onDrop(event)">
          <div class="upload-icon">📁</div>
          <p>クリックまたはドラッグ&ドロップで追加</p>
          <small>対応形式：JPG・PNG・GIF・MP4・MOV（最大20MB）</small>
        </div>
        <input type="file" id="media-input" multiple accept="image/*,video/*" style="display:none" onchange="handleMediaUpload(event)">
        <div class="media-grid" id="media-preview"></div>
      </div>
      <div style="display:flex;justify-content:flex-end;gap:10px;padding-top:8px">
        <button class="btn btn-secondary" onclick="cancelEdit()">✖ キャンセル</button>
        <button class="btn btn-primary" onclick="saveManual()">💾 保存する</button>
      </div>
      <input type="hidden" id="edit-id" value="">
    </div>

    <div id="detail-view">
      <div class="print-title" style="display:none"></div>
      <div class="print-meta" style="display:none"></div>
      <div class="detail-header">
        <div class="detail-header-info">
          <div class="breadcrumb" id="detail-breadcrumb"></div>
          <h2 id="detail-title"></h2>
        </div>
        <div class="detail-header-actions print-hide">
          <button class="btn btn-secondary" onclick="showAllManuals()">← 一覧</button>
          <button class="btn btn-secondary" onclick="editCurrentManual()">✏️ 編集</button>
          <button class="btn btn-success" onclick="printManual()">🖨️ 印刷</button>
        </div>
      </div>
      <div id="detail-body"></div>
    </div>
  </main>
</div>

<div id="history-panel">
  <div id="history-panel-header">
    <h3 style="font-size:15px;font-weight:700">📜 変更履歴（最大10件）</h3>
    <button id="close-history-btn" onclick="toggleHistory()">✕</button>
  </div>
  <div class="history-list" id="history-list"></div>
</div>

<nav id="mobile-nav">
  <div class="mobile-nav-inner">
    <button class="mobile-nav-btn active" id="mnav-list" onclick="mobileNav('list')"><span class="nav-icon">📂</span>一覧</button>
    <button class="mobile-nav-btn" id="mnav-new" onclick="mobileNav('new')"><span class="nav-icon">➕</span>新規</button>
    <button class="mobile-nav-btn" id="mnav-history" onclick="mobileNav('history')"><span class="nav-icon">📜</span>履歴</button>
    <button class="mobile-nav-btn" id="mnav-menu" onclick="mobileNav('menu')"><span class="nav-icon">☰</span>メニュー</button>
  </div>
</nav>

<div id="mobile-sidebar">
  <div style="padding:12px 16px 8px;border-bottom:1px solid var(--border)">
    <input type="text" placeholder="🔍 検索..." style="width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;background:var(--bg);color:var(--text);font-size:13px;outline:none" oninput="filterList(this.value)">
  </div>
  <div id="mobile-category-list" style="padding:8px 0;overflow-y:auto;max-height:calc(100vh - 56px - 60px - 50px)"></div>
</div>

<div class="modal-overlay" id="reset-modal">
  <div class="modal">
    <h3>🗑️ 全データ削除</h3>
    <p>全てのマニュアルデータを削除します。この操作は取り消せません。<br>友人にアプリを渡す前に実行してください。</p>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('reset-modal')">キャンセル</button>
      <button class="btn btn-warning" onclick="exportData();closeModal('reset-modal')">先にエクスポート</button>
      <button class="btn btn-danger" onclick="resetAll()">全て削除する</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="delete-modal">
  <div class="modal">
    <h3>削除の確認</h3>
    <p id="delete-modal-msg">このマニュアルを削除しますか？</p>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('delete-modal')">キャンセル</button>
      <button class="btn btn-danger" onclick="confirmDelete()">削除する</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="restore-modal">
  <div class="modal">
    <h3>📜 この状態に戻しますか？</h3>
    <p id="restore-modal-msg"></p>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('restore-modal')">キャンセル</button>
      <button class="btn btn-primary" onclick="confirmRestore()">この状態に戻す</button>
    </div>
  </div>
</div>

<div id="toast-container"></div>

<script>
const DB_KEY='manual_app_v2',HIST_KEY='manual_app_history_v2',THEME_KEY='manual_app_theme';
let state={manuals:[],currentView:'welcome',currentId:null,editId:null,editMedia:[],editSteps:[],searchQuery:'',pendingDeleteId:null,pendingRestoreIndex:null,openCats:[],currentSub:null};
let historyStack=[];

const DB={
  load(){try{const r=localStorage.getItem(DB_KEY);return r?JSON.parse(r):[]}catch{return[]}},
  save(d){try{localStorage.setItem(DB_KEY,JSON.stringify(d));return true}catch(e){if(e.name==='QuotaExceededError')showToast('⚠️ストレージ容量が不足しています','warning',5000);return false}},
  loadHistory(){try{const r=sessionStorage.getItem(HIST_KEY);return r?JSON.parse(r):[]}catch{return[]}},
  saveHistory(h){try{sessionStorage.setItem(HIST_KEY,JSON.stringify(h))}catch{}}
};

function pushHistory(action,title){
  historyStack.unshift({action,title,snapshot:JSON.parse(JSON.stringify(state.manuals)),time:new Date().toLocaleString('ja-JP')});
  if(historyStack.length>10)historyStack=historyStack.slice(0,10);
  DB.saveHistory(historyStack);renderHistoryPanel();
}
function undoHistory(){
  if(!historyStack.length){showToast('⚠️戻れる履歴がありません','warning');return;}
  const prev=historyStack.shift();
  state.manuals=prev.snapshot;DB.save(state.manuals);DB.saveHistory(historyStack);
  renderSidebar();renderHistoryPanel();showAllManuals();showToast('↩ '+prev.action+'を元に戻しました','success');
}

document.addEventListener('DOMContentLoaded',()=>{
  state.manuals=DB.load();historyStack=DB.loadHistory();
  if(localStorage.getItem(THEME_KEY)==='dark')document.documentElement.setAttribute('data-theme','dark');
  renderSidebar();renderHistoryPanel();
  if(state.manuals.length>0)showAllManuals();
  document.addEventListener('keydown',e=>{
    if((e.ctrlKey||e.metaKey)&&!e.shiftKey&&e.key==='z'){e.preventDefault();undoHistory();}
    if((e.ctrlKey||e.metaKey)&&e.key==='s'){e.preventDefault();if(state.currentView==='edit')saveManual();}
  });
});

function renderSidebar(){
  const html=renderCategoryTree(buildCategoryTree(getFilteredManuals()));
  document.getElementById('category-list').innerHTML=html||'<div style="padding:20px;text-align:center;color:var(--text3);font-size:13px">マニュアルがありません</div>';
  const m=document.getElementById('mobile-category-list');
  if(m)m.innerHTML=document.getElementById('category-list').innerHTML;
  updateDatalist();
}
function buildCategoryTree(manuals){
  const tree={};
  manuals.forEach(m=>{
    const main=m.mainCat||'未分類',sub=m.subCat||'未分類';
    if(!tree[main])tree[main]={};
    if(!tree[main][sub])tree[main][sub]=[];
    tree[main][sub].push(m);
  });
  return tree;
}
function renderCategoryTree(tree){
  let html='';
  for(const[mc,subs]of Object.entries(tree)){
    const isOpen=state.openCats.includes(mc)?'open':'';
    const total=Object.values(subs).reduce((a,b)=>a+b.length,0);
    html+=`<div><div class="cat-main ${isOpen}" onclick="toggleCat(this,'${escA(mc)}')"><span>📁 ${escH(mc)} <small style="color:var(--text3);font-weight:400">(${total})</small></span><span class="arrow">▶</span></div><div class="cat-sub-list">`;
    for(const[sc,items]of Object.entries(subs)){
      html+=`<div class="cat-sub-item ${state.currentSub===sc?'active':''}" onclick="showSubCat('${escA(mc)}','${escA(sc)}')"><span>📄 ${escH(sc)}</span><span class="item-count">${items.length}</span></div>`;
    }
    html+=`</div></div>`;
  }
  return html;
}
function toggleCat(el,name){
  el.classList.toggle('open');
  if(state.openCats.includes(name))state.openCats=state.openCats.filter(c=>c!==name);
  else state.openCats.push(name);
}
function showSubCat(mc,sc){
  state.currentSub=sc;closeMobileSidebar();
  const items=state.manuals.filter(m=>m.mainCat===mc&&m.subCat===sc);
  showView('list');
  document.getElementById('list-title').innerHTML=`📂 ${escH(mc)} › ${escH(sc)} <span class="badge">${items.length}</span>`;
  document.getElementById('manual-cards-container').innerHTML=items.map(m=>renderCard(m)).join('')||'<div style="text-align:center;padding:40px;color:var(--text3)">マニュアルがありません</div>';
}
function updateDatalist(){
  document.getElementById('main-cat-list').innerHTML=[...new Set(state.manuals.map(m=>m.mainCat).filter(Boolean))].map(c=>`<option value="${escH(c)}">`).join('');
  document.getElementById('sub-cat-list').innerHTML=[...new Set(state.manuals.map(m=>m.subCat).filter(Boolean))].map(c=>`<option value="${escH(c)}">`).join('');
}

function showView(view){
  state.currentView=view;
  document.getElementById('welcome-screen').style.display=view==='welcome'?'flex':'none';
  document.getElementById('manual-list-view').style.display=view==='list'?'block':'none';
  document.getElementById('edit-view').style.display=view==='edit'?'block':'none';
  document.getElementById('detail-view').style.display=view==='detail'?'block':'none';
}
function showAllManuals(){
  const manuals=getFilteredManuals();showView('list');
  document.getElementById('list-title').innerHTML=`📂 全マニュアル一覧 <span class="badge">${manuals.length}</span>`;
  document.getElementById('manual-cards-container').innerHTML=manuals.map(m=>renderCard(m)).join('')||'<div style="text-align:center;padding:60px;color:var(--text3)"><div style="font-size:40px;margin-bottom:12px">📭</div><div>マニュアルがまだありません<br>「＋ 新規」から作成してください</div></div>';
}
function getFilteredManuals(){
  if(!state.searchQuery)return[...state.manuals];
  const q=state.searchQuery.toLowerCase();
  return state.manuals.filter(m=>(m.title||'').toLowerCase().includes(q)||(m.mainCat||'').toLowerCase().includes(q)||(m.subCat||'').toLowerCase().includes(q)||(m.desc||'').toLowerCase().includes(q));
}
function filterList(q){state.searchQuery=q;renderSidebar();if(state.currentView==='list')showAllManuals();}

function renderCard(m){
  const steps=(m.steps||[]).length,media=(m.media||[]).length;
  return`<div class="manual-card" onclick="showDetail('${m.id}')">
    <div class="card-badge">📁 ${escH(m.mainCat||'未分類')} › ${escH(m.subCat||'未分類')}</div>
    <h3>${escH(m.title||'無題')}</h3>
    <div class="card-desc">${escH((m.desc||'説明なし').slice(0,80))}${(m.desc||'').length>80?'…':''}</div>
    <div class="card-meta">
      <span>🔢 ${steps}工程 📎 ${media}メディア</span>
      <div class="card-actions">
        <button class="card-btn" onclick="event.stopPropagation();openEditForm('${m.id}')">✏️ 編集</button>
        <button class="card-btn danger" onclick="event.stopPropagation();showDeleteModal('${m.id}')">🗑️</button>
      </div>
    </div>
    <div style="font-size:11px;color:var(--text3);margin-top:6px">更新: ${m.updatedAt||m.createdAt||'不明'}</div>
  </div>`;
}

function showDetail(id){
  const m=state.manuals.find(x=>x.id===id);if(!m)return;
  state.currentId=id;showView('detail');
  document.querySelector('.print-title').textContent=m.title||'無題';
  document.querySelector('.print-meta').textContent=`大カテゴリー:${m.mainCat||'-'} 中カテゴリー:${m.subCat||'-'} 更新日:${m.updatedAt||'-'}`;
  document.getElementById('detail-title').textContent=m.title||'無題';
  document.getElementById('detail-breadcrumb').innerHTML=`<span>📁 ${escH(m.mainCat||'未分類')}</span> › <span>📄 ${escH(m.subCat||'未分類')}</span>`;
  let html='';
  if(m.desc)html+=`<div class="detail-section"><h3>📌 概要</h3><div class="detail-desc">${escH(m.desc)}</div></div>`;
  if(m.caution)html+=`<div class="detail-section"><h3>⚠️ 注意事項</h3><div class="caution-box">${escH(m.caution)}</div></div>`;
  if(m.steps&&m.steps.length>0){
    html+=`<div class="detail-section"><h3>🔢 作業工程</h3>`;
    m.steps.forEach((s,i)=>{
      html+=`<div class="step-detail-card"><div class="step-detail-num"><span>${i+1}</span> ${escH(s.name||`工程${i+1}`)}</div>`;
      if(s.desc)html+=`<div class="step-block"><div class="step-block-label">📝 作業内容</div><div class="step-block-text">${escH(s.desc)}</div></div>`;
      if(s.point)html+=`<div class="step-block"><div class="step-block-label">💡 ポイント</div><div class="point-box">${escH(s.point)}</div></div>`;
      if(s.caution)html+=`<div class="step-block"><div class="step-block-label">⚠️ 注意</div><div class="caution-box">${escH(s.caution)}</div></div>`;
      html+=`</div>`;
    });
    html+=`</div>`;
  }
  if(m.media&&m.media.length>0){
    html+=`<div class="detail-section"><h3>🖼️ 写真・動画</h3><div class="media-grid">`;
    m.media.forEach(med=>{
      html+=med.type==='image'
        ?`<div class="media-item"><img src="${med.data}" alt="${escH(med.name||'')}"><span class="media-type-badge">📸</span></div>`
        :`<div class="media-item"><video src="${med.data}" controls playsinline></video><span class="media-type-badge">🎬</span></div>`;
    });
    html+=`</div></div>`;
  }
  document.getElementById('detail-body').innerHTML=html;
}
function editCurrentManual(){if(state.currentId)openEditForm(state.currentId);}

function openNewForm(){
  state.editId=null;state.editMedia=[];state.editSteps=[createStep()];
  document.getElementById('form-title').textContent='✏️ 新規マニュアル作成';
  ['f-main-cat','f-sub-cat','f-title','f-desc','f-caution'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('edit-id').value='';
  renderSteps();renderMediaPreview();showView('edit');window.scrollTo(0,0);
}
function openEditForm(id){
  const m=state.manuals.find(x=>x.id===id);if(!m)return;
  state.editId=id;
  state.editMedia=JSON.parse(JSON.stringify(m.media||[]));
  state.editSteps=JSON.parse(JSON.stringify(m.steps&&m.steps.length>0?m.steps:[createStep()]));
  document.getElementById('form-title').textContent='✏️ マニュアル編集';
  document.getElementById('f-main-cat').value=m.mainCat||'';
  document.getElementById('f-sub-cat').value=m.subCat||'';
  document.getElementById('f-title').value=m.title||'';
  document.getElementById('f-desc').value=m.desc||'';
  document.getElementById('f-caution').value=m.caution||'';
  document.getElementById('edit-id').value=id;
  renderSteps();renderMediaPreview();showView('edit');window.scrollTo(0,0);
}
function cancelEdit(){if(state.currentId)showDetail(state.currentId);else showAllManuals();}

function createStep(){return{id:Date.now()+Math.random(),name:'',desc:'',point:'',caution:''};}
function addStep(){state.editSteps.push(createStep());renderSteps();}
function removeStep(idx){state.editSteps.splice(idx,1);if(!state.editSteps.length)state.editSteps.push(createStep());renderSteps();}
function renderSteps(){
  document.getElementById('step-list').innerHTML=state.editSteps.map((s,i)=>`
    <div class="step-card">
      <div class="step-card-header">
        <div class="step-number">${i+1}</div>
        <input type="text" placeholder="工程名（例：材料を準備する）" value="${escA(s.name)}" oninput="updateStep(${i},'name',this.value)" style="flex:1;border:none;background:transparent;font-weight:600;font-size:14px;color:var(--text);outline:none;padding:0">
        <button class="step-remove-btn" onclick="removeStep(${i})">✕</button>
      </div>
      <div class="step-fields">
        <div class="step-field-row">
          <div class="form-group" style="margin:0"><label>📝 作業内容</label><textarea rows="3" placeholder="この工程でやること" oninput="updateStep(${i},'desc',this.value)">${escH(s.desc)}</textarea></div>
          <div class="form-group" style="margin:0"><label>💡 ポイント</label><textarea rows="3" placeholder="うまくやるコツ" oninput="updateStep(${i},'point',this.value)">${escH(s.point)}</textarea></div>
        </div>
        <div class="form-group" style="margin:0"><label>⚠️ この工程の注意事項</label><textarea rows="2" placeholder="この工程で特に気をつけること" oninput="updateStep(${i},'caution',this.value)">${escH(s.caution)}</textarea></div>
      </div>
    </div>`).join('');
}
function updateStep(idx,field,value){if(state.editSteps[idx])state.editSteps[idx][field]=value;}

function handleMediaUpload(e){processFiles(Array.from(e.target.files));e.target.value='';}
function onDragOver(e){e.preventDefault();document.getElementById('upload-zone').classList.add('drag-over');}
function onDragLeave(){document.getElementById('upload-zone').classList.remove('drag-over');}
function onDrop(e){e.preventDefault();document.getElementById('upload-zone').classList.remove('drag-over');processFiles(Array.from(e.dataTransfer.files));}
function processFiles(files){
  files.forEach(file=>{
    if(file.size>20*1024*1024){showToast(`⚠️${file.name}は最大20MBを超えています`,'warning');return;}
    if(!file.type.startsWith('image/')&&!file.type.startsWith('video/')){showToast(`⚠️${file.name}は未対応の形式です`,'warning');return;}
    const reader=new FileReader();
    reader.onload=ev=>{state.editMedia.push({id:Date.now()+Math.random(),name:file.name,type:file.type.startsWith('image/')?'image':'video',data:ev.target.result});renderMediaPreview();};
    reader.readAsDataURL(file);
  });
}
function removeMedia(idx){state.editMedia.splice(idx,1);renderMediaPreview();}
function renderMediaPreview(){
  document.getElementById('media-preview').innerHTML=state.editMedia.map((med,i)=>
    med.type==='image'
      ?`<div class="media-item"><img src="${med.data}" alt="${escH(med.name||'')}"><button class="media-del" onclick="removeMedia(${i})">✕</button><span class="media-type-badge">📸</span></div>`
      :`<div class="media-item"><video src="${med.data}" controls playsinline style="background:#000"></video><button class="media-del" onclick="removeMedia(${i})">✕</button><span class="media-type-badge">🎬</span></div>`
  ).join('');
}

function saveManual(){
  const mainCat=document.getElementById('f-main-cat').value.trim();
  const subCat=document.getElementById('f-sub-cat').value.trim();
  const title=document.getElementById('f-title').value.trim();
  if(!mainCat){showToast('⚠️大カテゴリーを入力してください','warning');document.getElementById('f-main-cat').focus();return;}
  if(!subCat){showToast('⚠️中カテゴリーを入力してください','warning');document.getElementById('f-sub-cat').focus();return;}
  if(!title){showToast('⚠️タイトルを入力してください','warning');document.getElementById('f-title').focus();return;}
  const now=new Date().toLocaleString('ja-JP');
  const manual={
    id:state.editId||('m_'+Date.now()),mainCat,subCat,title,
    desc:document.getElementById('f-desc').value.trim(),
    caution:document.getElementById('f-caution').value.trim(),
    steps:JSON.parse(JSON.stringify(state.editSteps)),
    media:JSON.parse(JSON.stringify(state.editMedia)),updatedAt:now
  };
  const isNew=!state.editId;
  if(isNew){manual.createdAt=now;pushHistory('新規作成: '+title,title);state.manuals.unshift(manual);}
  else{
    pushHistory('更新: '+title,title);
    const idx=state.manuals.findIndex(m=>m.id===state.editId);
    if(idx!==-1){manual.createdAt=state.manuals[idx].createdAt;state.manuals[idx]=manual;}
  }
  if(DB.save(state.manuals)){state.currentId=manual.id;renderSidebar();showDetail(manual.id);showToast(isNew?'✅新規マニュアルを作成しました':'✅マニュアルを更新しました','success');}
}

function showDeleteModal(id){
  state.pendingDeleteId=id;
  const m=state.manuals.find(x=>x.id===id);
  document.getElementById('delete-modal-msg').textContent=`「${m?m.title:''}」を削除しますか？この操作は取り消せません。`;
  openModal('delete-modal');
}
function confirmDelete(){
  if(!state.pendingDeleteId)return;
  const m=state.manuals.find(x=>x.id===state.pendingDeleteId);
  pushHistory('削除: '+(m?m.title:''),m?m.title:'');
  state.manuals=state.manuals.filter(x=>x.id!==state.pendingDeleteId);
  DB.save(state.manuals);state.pendingDeleteId=null;state.currentId=null;
  closeModal('delete-modal');renderSidebar();showAllManuals();showToast('🗑️削除しました','danger');
}

function exportData(){
  const blob=new Blob([JSON.stringify({version:'2.0',exportedAt:new Date().toLocaleString('ja-JP'),manuals:state.manuals},null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);const a=document.createElement('a');
  a.href=url;a.download='manual_backup_'+new Date().toISOString().slice(0,10)+'.json';a.click();
  URL.revokeObjectURL(url);showToast('⬆️エクスポートしました','success');
}
function triggerImport(){document.getElementById('import-file-input').click();}
function importData(e){
  const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    try{
      const data=JSON.parse(ev.target.result);
      if(!data.manuals||!Array.isArray(data.manuals))throw new Error('不正なファイル形式');
      pushHistory('インポート','インポート');state.manuals=data.manuals;DB.save(state.manuals);
      renderSidebar();showAllManuals();showToast('⬇️'+data.manuals.length+'件インポートしました','success');
    }catch(err){showToast('⚠️読み込みに失敗しました: '+err.message,'danger');}
  };
  reader.readAsText(file);e.target.value='';
}

function showResetModal(){openModal('reset-modal');}
function resetAll(){
  state.manuals=[];DB.save(state.manuals);localStorage.removeItem(DB_KEY);sessionStorage.removeItem(HIST_KEY);
  historyStack=[];state.currentId=null;closeModal('reset-modal');
  renderSidebar();renderHistoryPanel();showView('welcome');showToast('🗑️全データを削除しました','danger',4000);
}

function printManual(){
  document.querySelector('.print-title').style.display='block';
  document.querySelector('.print-meta').style.display='block';
  window.print();
  setTimeout(()=>{document.querySelector('.print-title').style.display='none';document.querySelector('.print-meta').style.display='none';},1000);
}

function toggleHistory(){document.getElementById('history-panel').classList.toggle('open');}
function renderHistoryPanel(){
  const list=document.getElementById('history-list');
  if(!historyStack.length){list.innerHTML='<div class="history-empty">📭変更履歴がありません<br><small>保存するたびに記録されます</small></div>';return;}
  list.innerHTML=historyStack.map((h,i)=>`<div class="history-item" onclick="showRestoreModal(${i})"><div class="h-action">${escH(h.action)}</div><div class="h-title">📋 ${escH(h.title||'')}</div><div class="h-time">🕐 ${h.time}</div></div>`).join('');
}
function showRestoreModal(idx){
  state.pendingRestoreIndex=idx;
  const h=historyStack[idx];
  document.getElementById('restore-modal-msg').textContent=`「${h.action}」（${h.time}）の状態に戻しますか？`;
  openModal('restore-modal');
}
function confirmRestore(){
  if(state.pendingRestoreIndex===null)return;
  const h=historyStack[state.pendingRestoreIndex];
  state.manuals=JSON.parse(JSON.stringify(h.snapshot));DB.save(state.manuals);
  closeModal('restore-modal');historyStack=historyStack.slice(state.pendingRestoreIndex+1);
  DB.saveHistory(historyStack);renderSidebar();renderHistoryPanel();showAllManuals();showToast('↩履歴を復元しました','success');
}

function toggleDark(){
  const isDark=document.documentElement.getAttribute('data-theme')==='dark';
  if(isDark){document.documentElement.removeAttribute('data-theme');localStorage.setItem(THEME_KEY,'light');showToast('☀️ライトモード');}
  else{document.documentElement.setAttribute('data-theme','dark');localStorage.setItem(THEME_KEY,'dark');showToast('🌙ダークモード');}
}

